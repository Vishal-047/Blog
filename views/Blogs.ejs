<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title>Home Page</title>
</head>
<body>
    <%- include('./partials/navbar.ejs', { user: user, userBlogs: userBlogs }) %>
    <div class="container mt-3 px-2 py-4">
        <article class="blog-article">
        <div class="blog-article-title">
        <%= blog.title %>
        </div>
        <div class="container mt-3">    
            <%
                const imageName = blog.coverImage || blog.coverimage;
                const imageSrc = imageName
                    ? (imageName.startsWith('http') || imageName.startsWith('/') ? imageName : `/uploads/${imageName}`)
                    : 'https://via.placeholder.com/900x500?text=No+Image';
            %>
            <img src="<%= imageSrc %>" alt="Blog Image" class="blog-article-image">
        </div>
        <div class="container mt-3 blog-article-body">
    <pre><%= blog.body %></pre>
        </div>
        <div class="container mt-3 blog-article-body">
            <%= blog.createdBy.fullName %>
        </div>
        </article>
        <section class="comment-section mt-4">
            <h3 class="comment-heading">Comments (<%= comments.length %>)</h3>
            <% if (locals.user) { %>
                <form action="/blog/comment/<%= blog._id %>" method="post" class="comment-form mt-3">
                    <div>
                        <input type="text" name="content" placeholder="Write your comment..." class="form-control comment-input" required>
                    </div>
                    <button class="btn btn-primary comment-submit-btn mt-3">Post Comment</button>
                </form>
            <% } %>
            <% if (!locals.user) { %>
                <div class="container mt-3">
                    Please SignIn to post Comments.
                </div>
            <% } %>
            <div class="comment-list mt-3">
                <% (comments || []).forEach(comment => { %>
                    <article class="comment-card">
                        <div class="comment-author">
                            <%= comment.createdBy.fullName %>
                        </div>
                        <div class="comment-text">
                            <%= comment.content %>
                        </div>
                    </article>
                <% }) %>
            </div>
            <% if (!comments || comments.length === 0) { %>
                <p class="comment-empty mt-2">No comments yet. Start the discussion.</p>
            <% } %>
        </section>
    </div>
    <%- include('./partials/script.ejs') %>
</body>
</html>
