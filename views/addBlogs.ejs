<!DOCTYPE html>
<html lang="en">
<head>
    <%-include('./partials/head.ejs') -%>
    <title>Create Blog</title>
</head>
<body>
    <%-include('./partials/navbar.ejs', { user: user, userBlogs: userBlogs }) -%>
    <div class="container mt-4 mb-5">
      <form action="/blog" method="POST" enctype="multipart/form-data" class="create-blog-form">
      <h2 class="create-blog-title">Create New Blog</h2>
  <div class="mt-3">
      <label for="coverImage" class="form-label">Cover Image</label>
      <input type="file" name="coverImage"  class="form-control" id="coverImage" aria-describedby="coverImage">
  </div>
  <div class="mt-3">
      <label for="title" name="title" class="form-label">Title</label>
      <input type="text" name="title" placeholder="Enter the title of your Blog" class="form-control" id="title" aria-describedby="title">
  </div>
      <div class="mt-3">
          <label for="body" class="form-label">Content</label>
          <textarea class="form-control" name="body" placeholder="Write the content of your Blog" id="body" style="height: 180px"></textarea>
        </div>
      <div class="mt-4">
          <button class="btn btn-primary px-4">Publish</button>
        </div>

  </form>
  </div>
    <%-include('./partials/script.ejs') -%>

</body>
</html>
