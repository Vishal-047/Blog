<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head.ejs') %>
  <title>Change Password</title>
</head>
<body>
  <%- include('./partials/navbar.ejs', { user: user }) %>

  <div class="container mt-4">
    <section class="create-blog-form">
      <h2 class="create-blog-title">Change Password</h2>
      <p class="text-muted">Use a strong password with at least 8 characters.</p>

      <% if (success === 'password-updated') { %>
        <div class="alert alert-success">Password changed successfully.</div>
      <% } %>
      <% if (locals.error) { %>
        <div class="alert alert-danger"><%= locals.error %></div>
      <% } %>

      <form method="POST" action="/user/change-password" class="row g-3 mt-1">
        <div class="col-12">
          <label class="form-label" for="currentPassword">Current Password</label>
          <input class="form-control" type="password" id="currentPassword" name="currentPassword" required>
        </div>

        <div class="col-12">
          <label class="form-label" for="newPassword">New Password</label>
          <input class="form-control" type="password" id="newPassword" name="newPassword" required>
        </div>

        <div class="col-12">
          <label class="form-label" for="confirmPassword">Confirm New Password</label>
          <input class="form-control" type="password" id="confirmPassword" name="confirmPassword" required>
        </div>

        <div class="col-12 d-flex gap-2 flex-wrap">
          <button class="btn btn-primary px-4" type="submit">Update Password</button>
          <a class="btn btn-outline-secondary" href="/user/settings">Back to Settings</a>
        </div>
      </form>
    </section>
  </div>

  <%- include('./partials/script.ejs') %>
</body>
</html>
