<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title>Home Page</title>
</head>
<body>
    <%- include('./partials/navbar.ejs', { user: user }) %>

    <div class="container mt-4">
        <div class="hero-banner mb-4">
            <h1 class="hero-title">Latest Stories</h1>
            <p class="hero-subtitle">Read ideas, notes, and updates from the community.</p>
        </div>

        <div class="blog-grid">

            <% (blog || []).forEach(blog => { %>

            <div class="card blog-card">
                <% 
                    const imageName = blog.coverImage || blog.coverimage;
                    const imageSrc = imageName
                        ? (imageName.startsWith('http') || imageName.startsWith('/') ? imageName : `/uploads/${imageName}`)
                        : 'https://via.placeholder.com/286x180?text=No+Image';
                %>
                <img src="<%= imageSrc %>" class="card-img-top blog-card-image" alt="Blog cover image">
                <div class="card-body">
                    <h5 class="card-title blog-card-title"><%=blog.title%></h5>
                    <p class="blog-meta">By <%= blog.createdBy?.fullName || 'Anonymous' %></p>
                    <a href="/blog/<%= blog._id %>" class="btn btn-primary blog-card-btn">Read Post</a>
                </div>
            </div>

            <% }) %>

        </div>

        <% if (pagination && pagination.totalPages > 1) { %>
            <nav class="mt-4" aria-label="Blog pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item <%= pagination.currentPage <= 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="/?page=<%= pagination.currentPage - 1 %>">Previous</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">
                            Page <%= pagination.currentPage %> of <%= pagination.totalPages %>
                        </span>
                    </li>
                    <li class="page-item <%= pagination.currentPage >= pagination.totalPages ? 'disabled' : '' %>">
                        <a class="page-link" href="/?page=<%= pagination.currentPage + 1 %>">Next</a>
                    </li>
                </ul>
            </nav>
        <% } %>

    </div>

    <%- include('./partials/script.ejs') %>
</body>
</html>
