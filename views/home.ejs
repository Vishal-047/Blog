<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title>Home Page</title>
</head>
<body>
    <%- include('./partials/navbar.ejs') %>

    <div class="container mt-4">
        <div class="hero-banner mb-4">
            <h1 class="hero-title">Latest Stories</h1>
            <p class="hero-subtitle">Read ideas, notes, and updates from the community.</p>
        </div>

        <div class="blog-grid">

            <% (blog || []).forEach(blog => { %>

            <div class="card blog-card">
                <% 
                    const imageName = blog.coverImage || blog.coverimage;
                    const imageSrc = imageName
                        ? (imageName.startsWith('http') || imageName.startsWith('/') ? imageName : `/uploads/${imageName}`)
                        : 'https://via.placeholder.com/286x180?text=No+Image';
                %>
                <img src="<%= imageSrc %>" class="card-img-top blog-card-image" alt="Blog cover image">
                <div class="card-body">
                    <h5 class="card-title blog-card-title"><%=blog.title%></h5>
                    <a href="/blog/<%= blog._id %>" class="btn btn-primary blog-card-btn">Read Post</a>
                </div>
            </div>

            <% }) %>

        </div>

    </div>

    <h1>
        To be added...
        <pre>
            1. Show own created blog to user, for that create a different section
            2. show option to edit users own blog content, title or change photo
            3. show option to delete the blog, change the password
        </pre>
    </h1>

    <%- include('./partials/script.ejs') %>
</body>
</html>
