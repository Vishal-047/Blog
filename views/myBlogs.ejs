<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title>My Blogs</title>
</head>
<body>
    <%- include('./partials/navbar.ejs') %>

    <div class="container mt-4">
        <div class="hero-banner mb-4">
            <h1 class="hero-title">My Blogs</h1>
            <p class="hero-subtitle">Manage your own posts here (view/edit/delete).</p>
        </div>

        <% if (userBlogs && userBlogs.length > 0) { %>
            <div class="blog-grid">
                <% userBlogs.forEach(blog => { %>
                <div class="card blog-card my-blog-card">
                    <% 
                        const imageName = blog.coverImage || blog.coverimage;
                        const imageSrc = imageName
                            ? (imageName.startsWith('http') || imageName.startsWith('/') ? imageName : `/uploads/${imageName}`)
                            : 'https://via.placeholder.com/286x180?text=No+Image';
                    %>
                    <img src="<%= imageSrc %>" class="card-img-top blog-card-image" alt="Blog cover image">
                    <div class="card-body">
                        <h5 class="card-title blog-card-title"><%= blog.title %></h5>
                        <p class="blog-meta">Created on <%= blog.createdAt.toLocaleDateString() %></p>
                        <div class="blog-actions">
                            <a href="/blog/<%= blog._id %>" class="btn btn-primary btn-sm">View</a>
                            <a href="/blog/edit/<%= blog._id %>" class="btn btn-warning btn-sm">Edit</a>
                            <form method="POST" action="/blog/delete/<%= blog._id %>" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this blog?');">
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="alert alert-info" role="alert">
                You have no blogs yet. <a href="/blog/createBlog" class="alert-link">Create one now.</a>
            </div>
        <% } %>
    </div>

    <%- include('./partials/script.ejs') %>
</body>
</html>
