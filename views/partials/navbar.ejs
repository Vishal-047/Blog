<style>
  .app-navbar {
    background: rgba(15, 23, 42, 0.92) !important;
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(148, 163, 184, 0.2);
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.2);
  }

  .app-navbar .navbar-brand {
    font-weight: 700;
    letter-spacing: 0.3px;
    color: #f8fafc;
  }

  .app-navbar .nav-link {
    color: #cbd5e1 !important;
    font-weight: 500;
    margin-right: 8px;
    border-radius: 8px;
    transition: all 0.2s ease;
    padding: 8px 12px !important;
  }

  .app-navbar .nav-link:hover,
  .app-navbar .nav-link.active {
    color: #ffffff !important;
    background: rgba(148, 163, 184, 0.2);
  }

  .app-navbar .nav-link[href*="createBlog"] {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(168, 85, 247, 0.2));
    border: 1px solid rgba(59, 130, 246, 0.4);
    color: #60a5fa !important;
    font-weight: 600;
  }

  .app-navbar .nav-link[href*="createBlog"]:hover {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.3), rgba(168, 85, 247, 0.3));
    border-color: rgba(59, 130, 246, 0.6);
    color: #93c5fd !important;
  }

  .app-navbar .dropdown-menu {
    border-radius: 10px;
    border: 1px solid rgba(148, 163, 184, 0.3);
    box-shadow: 0 8px 20px rgba(2, 6, 23, 0.15);
    max-height: 400px;
    overflow-y: auto;
  }

  .app-navbar .dropdown-item {
    color: #334155;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .app-navbar .dropdown-item:hover {
    background: rgba(59, 130, 246, 0.1);
    color: #1e40af;
  }

  .app-navbar .blog-dropdown-item {
    display: flex;
    align-items: center;
    padding: 8px 16px;
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
  }

  .app-navbar .blog-dropdown-item:last-child {
    border-bottom: none;
  }

  .app-navbar .blog-dropdown-title {
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
  }

  .app-navbar .blog-dropdown-date {
    font-size: 0.75rem;
    color: #64748b;
    margin-bottom: 4px;
  }

  .app-navbar .blog-dropdown-actions {
    display: flex;
    gap: 4px;
    margin-left: auto;
  }

  .app-navbar .blog-dropdown-actions .btn {
    font-size: 0.7rem;
    padding: 2px 6px;
    border-radius: 4px;
  }
</style>

<nav class="navbar navbar-expand-lg app-navbar" data-bs-theme="dark">
  <div class="container-fluid">
    <a class="navbar-brand" href="/">Blogging</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavDropdown">
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link active" aria-current="page" href="/">Home</a>
        </li>
        <% if (locals.user) { %>
          <li class="nav-item">
            <a class="nav-link" href="/myblogs">My Blogs</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/blog/createBlog">Create Blog</a>
          </li>
        <% } %>
      </ul>
      <ul class="navbar-nav ms-auto">
        <% if (locals.user) { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <%= locals.user.email %>
            </a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/user/logout">Logout</a></li>
            </ul>
          </li></ul>
        <% } else { %>
          <li class="nav-item">
          <a class="nav-link active" href="/user/signin" aria-current="page">Create Blog</a>
        </li>
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/user/signin">Sign In</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/user/signup">Create Account</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<% if (locals.error) { %>
  <div class="container mt-5">
    <div class="alert alert-danger" role="alert">
      <%= locals.error %>
    </div>
  </div>

<% } %>
